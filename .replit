modules = ["nodejs-24", "python-base-3.13"]

[deployment]
deploymentTarget = "vm"
run = ["bash", "scripts/start-production.sh"]

[deployment.postBuild]
args = ["bash", "-c", "pnpm store prune && cd discord-bot && npm install --production"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Discord Bot"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Discord Bot 2"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Telegram Bot"

[[workflows.workflow]]
name = "Discord Bot"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd discord-bot && node index.js"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Discord Bot 2"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd discord-bot-2 && npm install && node index.js"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Telegram Bot"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd telegram-bot && node index.js"

[workflows.workflow.metadata]
outputType = "console"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[userenv]

[userenv.shared]
OWNER_ID_1 = "1191762996444278826"
PUPPETEER_EXECUTABLE_PATH = "/nix/store/qa9cnw4v5xkxyip6mb9kxqfq1z4x2dx1-chromium-138.0.7204.100/bin/chromium"

[nix]
channel = "stable-25_05"

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 25104
externalPort = 3000
